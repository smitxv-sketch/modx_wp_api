# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MySQL Database Credentials for MODX Research
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="modx_database"
DB_PREFIX="modx_"

# Password for Vercel deployment Basic Auth
SITE_PASSWORD="my_secret_password"
